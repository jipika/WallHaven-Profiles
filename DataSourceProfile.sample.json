{
  "schemaVersion": "1.0.0",
  "profiles": [
    {
      "id": "wallhaven-motionbgs-default",
      "name": "WallHaven + MotionBGs",
      "description": "Built-in default profile: WallHaven wallpaper API with MotionBGs dynamic wallpaper media source.",
      "wallpaper": {
        "provider": "wallhaven_api",
        "displayName": "WallHaven",
        "apiBaseURL": "https://wallhaven.cc/api/v1",
        "searchPath": "/search",
        "wallpaperPath": "/w/{id}",
        "imageURLTemplate": "https://w.wallhaven.cc/full/{prefix}/wallhaven-{id}.{ext}",
        "authHeaderName": "X-API-Key"
      },
      "media": {
        "provider": "motionbgs_html",
        "displayName": "MotionBGs",
        "baseURL": "https://motionbgs.com",
        "headers": {
          "User-Agent": "Mozilla/5.0 (Macintosh; Intel Mac OS X 14_0) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0 Safari/537.36",
          "Accept-Language": "en-US,en;q=0.9"
        },
        "routes": {
          "home": "/",
          "mobile": "/mobile/",
          "tag": "/tag:{slug}/",
          "search": "/search?q={query}",
          "detail": "/{slug}"
        },
        "parsing": {
          "searchList": "//div[contains(@class, 'flex flex-col')]/a",
          "searchName": ".//img/@alt",
          "searchResult": "@href",
          "searchCover": ".//img/@src",
          "nextPage": "//a[contains(text(), 'Next')]/@href | //a[@rel='next']/@href | //button[@hx-get]/@hx-get",
          "detailList": "//div[contains(@class, 'download-links')]//a",
          "detailName": ".//span[contains(@class, 'font-bold')]/text()",
          "detailLink": "@href",
          "tagList": "//a[contains(@href, '/tag:')]",
          "tagName": ".//span/text()"
        }
      }
    },
    {
      "id": "custom-template",
      "name": "Custom Profile Template",
      "description": "Template for creating a custom data source profile. Copy and modify this as a starting point.",
      "wallpaper": {
        "provider": "your_provider_id",
        "displayName": "Your Wallpaper Source Name",
        "apiBaseURL": "https://api.example.com/v1",
        "searchPath": "/search",
        "wallpaperPath": "/wallpaper/{id}",
        "imageURLTemplate": "https://cdn.example.com/images/{prefix}/{id}.{ext}",
        "authHeaderName": "Authorization"
      },
      "media": {
        "provider": "your_media_html_provider",
        "displayName": "Your Media Site Name",
        "baseURL": "https://example.com",
        "headers": {
          "User-Agent": "Mozilla/5.0 (Macintosh; Intel Mac OS X 14_0) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0 Safari/537.36",
          "Accept-Language": "en-US,en;q=0.9"
        },
        "routes": {
          "home": "/",
          "mobile": "/m/",
          "tag": "/tag/{slug}",
          "search": "/search?q={query}",
          "detail": "/wallpaper/{slug}"
        },
        "parsing": {
          "searchList": "//div[@class='results']//article",
          "searchName": ".//h3[@class='title']/text()",
          "searchResult": ".//a[@class='thumb']/@href",
          "searchCover": ".//img[@class='cover']/@src",
          "nextPage": "//a[@class='next-page']/@href",
          "detailList": "//div[@class='download-options']//a",
          "detailName": ".//h1[@class='wallpaper-title']/text()",
          "detailLink": "@href",
          "tagList": "//div[@class='tags']//a",
          "tagName": "text()"
        }
      }
    }
  ]
}
